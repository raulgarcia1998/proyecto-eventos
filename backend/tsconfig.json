{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    
    /* Environment Settings */
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["esnext"],
    "types": ["node"],
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true,

    /* Stricter Typechecking */
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,

    /* Output */
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}